#if false
using UnityEngine;
using UnityEngine.EventSystems;
using UnityEngine.InputSystem;
using System.Collections;
using System.Collections.Generic;
using System.Linq;

namespace TheHero.Generated
{
    // Deprecated movement duplicate. Current Map scene uses THStrictGridHeroMovement.
    // Kept for reference only; do not attach together with the strict grid mover.
    public class THGuaranteedHeroMovement : MonoBehaviour
    {
        public float moveSpeed = 4f;
        public int movementPoints = THBalanceConfig.HeroMaxMovementPoints;
        
        private bool isMoving = false;
        private Camera mainCamera;
        private SpriteRenderer spriteRenderer;

        private void Start()
        {
            mainCamera = Camera.main;
            spriteRenderer = GetComponent<SpriteRenderer>();
            
            // Ensure visibility
            if (spriteRenderer != null)
            {
                spriteRenderer.enabled = true;
                spriteRenderer.sortingOrder = 50;
            }
            transform.localScale = Vector3.one;
            Vector3 p = transform.position;
            p.z = 0;
            transform.position = p;

            // Ensure Collider
            if (GetComponent<Collider2D>() == null)
            {
                gameObject.AddComponent<BoxCollider2D>().isTrigger = true;
            }

            Debug.Log("[TheHeroFix] Guaranteed hero movement installed");
        }

        private void Update()
        {
            if (isMoving) return;

            if (Mouse.current != null && Mouse.current.leftButton.wasPressedThisFrame)
            {
                if (EventSystem.current != null && EventSystem.current.IsPointerOverGameObject())
                    return;

                HandleClick();
            }
        }

        private void HandleClick()
        {
            Vector2 mousePos = Mouse.current.position.ReadValue();
            Vector3 worldPoint = mainCamera.ScreenToWorldPoint(new Vector3(mousePos.x, mousePos.y, -mainCamera.transform.position.z));
            worldPoint.z = 0;

            // Find target tile
            RaycastHit2D hit = Physics2D.Raycast(worldPoint, Vector2.zero);
            THTile targetTile = null;
            if (hit.collider != null)
            {
                targetTile = hit.collider.GetComponent<THTile>();
            }

            if (targetTile != null)
            {
                if (targetTile.walkable)
                {
                    StartCoroutine(MoveRoutine(targetTile.transform.position));
                }
                else
                {
                    Debug.Log("[TH] Tile is not walkable: " + targetTile.tileType);
                }
            }
            else
            {
                // Fallback: move to snapped grid position if no tile hit
                Vector3 snapped = new Vector3(Mathf.Round(worldPoint.x), Mathf.Round(worldPoint.y), 0);
                StartCoroutine(MoveRoutine(snapped));
            }
        }

        private IEnumerator MoveRoutine(Vector3 targetPos)
        {
            isMoving = true;
            targetPos.z = 0;

            while (Vector3.Distance(transform.position, targetPos) > 0.01f)
            {
                transform.position = Vector3.MoveTowards(transform.position, targetPos, moveSpeed * Time.deltaTime);
                yield return null;
            }

            transform.position = targetPos;
            isMoving = false;

            // Update global state if possible
            if (THManager.Instance != null && THManager.Instance.Data != null)
            {
                THManager.Instance.Data.heroX = transform.position.x;
                THManager.Instance.Data.heroY = transform.position.y;
                // THManager.Instance.SaveGame();
                }

            if (THMapController.Instance != null)
            {
                THMapController.Instance.UpdateUI();
            }
        }
    }
}

#endif